# Server configuration
PORT=5000

# Environment (development or production)
NODE_ENV=development

# MongoDB Connection String
# DO NOT put your real production password here!
MONGO_URI="mongodb://username:password@cluster-url/jobmatch?retryWrites=true&w=majority"

# JWT Secret
# Generate a strong 64-character hex string for this in production
JWT_SECRET="your_strong_random_jwt_secret_here"

# Gmail SMTP Authentication for OTP
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-16-character-app-password"
